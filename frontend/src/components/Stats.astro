---
// Stats.astro - premium stat cards with animated counters
---

<div class="glass-card p-7 animate-slide-up" style="animation-delay: 0.08s;">
  <div class="section-title">
    <div class="icon-wrap">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
      </svg>
    </div>
    <div>
      <h2 class="text-slate-100 font-semibold text-base leading-none">Statistics</h2>
      <p class="text-xs text-slate-500 mt-1">Total files organized per category</p>
    </div>
  </div>

  <div id="stats-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
    <div class="skeleton h-28 rounded-xl"></div>
    <div class="skeleton h-28 rounded-xl"></div>
    <div class="skeleton h-28 rounded-xl"></div>
    <div class="skeleton h-28 rounded-xl"></div>
    <div class="skeleton h-28 rounded-xl"></div>
  </div>
</div>

<style>
  .stat-card {
    position: relative; border-radius: 14px; padding: 1.25rem 1.4rem;
    display: flex; flex-direction: column; gap: 0.5rem; cursor: default;
    transition: transform 0.25s cubic-bezier(.34,1.56,.64,1), box-shadow 0.25s ease;
    overflow: hidden;
  }
  .stat-card::before {
    content: ''; position: absolute; inset: 0; border-radius: 14px;
    opacity: 0; transition: opacity 0.25s ease;
  }
  .stat-card:hover { transform: translateY(-4px); }
  .stat-card:hover::before { opacity: 1; }

  .sc-images { background: rgba(99,179,237,0.07);  border: 1px solid rgba(99,179,237,0.18); }
  .sc-images::before { background: radial-gradient(circle at 70% 30%, rgba(99,179,237,0.12), transparent 60%); }
  .sc-images:hover { box-shadow: 0 8px 32px rgba(99,179,237,0.2); }
  .sc-images .sc-count { color: #63b3ed; }
  .sc-images .sc-icon-wrap { background: rgba(99,179,237,0.15); }

  .sc-videos { background: rgba(252,129,74,0.07);  border: 1px solid rgba(252,129,74,0.18); }
  .sc-videos::before { background: radial-gradient(circle at 70% 30%, rgba(252,129,74,0.12), transparent 60%); }
  .sc-videos:hover { box-shadow: 0 8px 32px rgba(252,129,74,0.2); }
  .sc-videos .sc-count { color: #fc814a; }
  .sc-videos .sc-icon-wrap { background: rgba(252,129,74,0.15); }

  .sc-docs { background: rgba(104,211,145,0.07); border: 1px solid rgba(104,211,145,0.18); }
  .sc-docs::before { background: radial-gradient(circle at 70% 30%, rgba(104,211,145,0.12), transparent 60%); }
  .sc-docs:hover { box-shadow: 0 8px 32px rgba(104,211,145,0.2); }
  .sc-docs .sc-count { color: #68d391; }
  .sc-docs .sc-icon-wrap { background: rgba(104,211,145,0.15); }

  .sc-music { background: rgba(183,148,246,0.07); border: 1px solid rgba(183,148,246,0.18); }
  .sc-music::before { background: radial-gradient(circle at 70% 30%, rgba(183,148,246,0.12), transparent 60%); }
  .sc-music:hover { box-shadow: 0 8px 32px rgba(183,148,246,0.2); }
  .sc-music .sc-count { color: #b794f6; }
  .sc-music .sc-icon-wrap { background: rgba(183,148,246,0.15); }

  .sc-others { background: rgba(160,174,192,0.07); border: 1px solid rgba(160,174,192,0.18); }
  .sc-others::before { background: radial-gradient(circle at 70% 30%, rgba(160,174,192,0.12), transparent 60%); }
  .sc-others:hover { box-shadow: 0 8px 32px rgba(160,174,192,0.15); }
  .sc-others .sc-count { color: #a0aec0; }
  .sc-others .sc-icon-wrap { background: rgba(160,174,192,0.12); }

  .sc-icon-wrap { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; }
  .sc-label { font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; color:#8892a4; }
  .sc-count { font-size:2rem; font-weight:800; line-height:1; font-variant-numeric:tabular-nums; }
</style>

<script>
  declare const window: Window & {
    go?: { main?: { App?: {
      GetStats: () => Promise<{ images: number; videos: number; docs: number; music: number; others: number }>;
    } } };
    refreshStats?: () => void;
  };

  const categories = [
    { key: "images", label: "Images", cls: "sc-images",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>` },
    { key: "videos", label: "Videos", cls: "sc-videos",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>` },
    { key: "docs",   label: "Docs",   cls: "sc-docs",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>` },
    { key: "music",  label: "Music",  cls: "sc-music",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg>` },
    { key: "others", label: "Others", cls: "sc-others",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM4 7V5a2 2 0 012-2h12a2 2 0 012 2v2"/></svg>` },
  ];

  function animateCount(el: HTMLElement, target: number) {
    const duration = 650, start = performance.now();
    function tick(now: number) {
      const t = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - t, 3);
      el.textContent = String(Math.round(target * ease));
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  async function loadStats() {
    const grid = document.getElementById("stats-grid") as HTMLDivElement;
    const App = window.go?.main?.App;

    try {
      let data: Record<string, number>;
      if (App) {
        const result = await App.GetStats();
        data = result as unknown as Record<string, number>;
      } else {
        data = { images: 0, videos: 0, docs: 0, music: 0, others: 0 };
      }

      grid.innerHTML = categories.map(c => `
        <div class="stat-card ${c.cls}">
          <div class="sc-icon-wrap">${c.svg}</div>
          <span class="sc-label">${c.label}</span>
          <span class="sc-count" data-target="${data[c.key] ?? 0}">0</span>
        </div>`).join("");
      grid.querySelectorAll<HTMLElement>(".sc-count").forEach(el =>
        animateCount(el, parseInt(el.dataset.target ?? "0", 10))
      );
    } catch {
      grid.innerHTML = `<p class="col-span-5 text-sm text-red-400 py-2">Could not load stats.</p>`;
    }
  }

  window.refreshStats = loadStats;
  loadStats();
</script>
