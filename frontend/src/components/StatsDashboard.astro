---
// StatsDashboard.astro – stat cards powered by Wails GetStats()
---

<div class="glass-card p-7 animate-slide-up" style="animation-delay: 0.08s;">
  <div class="section-title">
    <div class="icon-wrap">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="color:#888888" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
      </svg>
    </div>
    <div>
      <h2 class="font-semibold text-base leading-none" style="color:#ffffff;">Statistics</h2>
      <p class="text-xs mt-1" style="color:#555555;">Total files organized per category</p>
    </div>
  </div>

  <div id="stats-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
    <div class="skeleton h-28 rounded-xl"></div>
    <div class="skeleton h-28 rounded-xl"></div>
    <div class="skeleton h-28 rounded-xl"></div>
    <div class="skeleton h-28 rounded-xl"></div>
    <div class="skeleton h-28 rounded-xl"></div>
  </div>
</div>

<style>
  .stat-card {
    position: relative; border-radius: 14px; padding: 1.25rem 1.4rem;
    display: flex; flex-direction: column; gap: 0.5rem; cursor: default;
    transition: transform 0.25s cubic-bezier(.34,1.56,.64,1), box-shadow 0.25s ease;
    overflow: hidden;
  }
  .stat-card::before {
    content: ''; position: absolute; inset: 0; border-radius: 14px;
    opacity: 0; transition: opacity 0.25s ease;
  }
  .stat-card:hover { transform: translateY(-4px); }
  .stat-card:hover::before { opacity: 1; }

  /* All cards: same dark bg, white border — differentiated only by icon opacity tier */
  .sc-images  { background: #141414; border: 1px solid rgba(255,255,255,0.12); }
  .sc-images::before  { background: radial-gradient(circle at 70% 30%, rgba(255,255,255,0.05), transparent 60%); }
  .sc-images:hover    { box-shadow: 0 8px 32px rgba(255,255,255,0.08); }
  .sc-images .sc-count  { color: #ffffff; }
  .sc-images .sc-icon-wrap { background: rgba(255,255,255,0.08); }

  .sc-videos  { background: #141414; border: 1px solid rgba(255,255,255,0.12); }
  .sc-videos::before  { background: radial-gradient(circle at 70% 30%, rgba(255,255,255,0.05), transparent 60%); }
  .sc-videos:hover    { box-shadow: 0 8px 32px rgba(255,255,255,0.08); }
  .sc-videos .sc-count  { color: #ffffff; }
  .sc-videos .sc-icon-wrap { background: rgba(255,255,255,0.08); }

  .sc-docs   { background: #141414; border: 1px solid rgba(255,255,255,0.12); }
  .sc-docs::before   { background: radial-gradient(circle at 70% 30%, rgba(255,255,255,0.05), transparent 60%); }
  .sc-docs:hover     { box-shadow: 0 8px 32px rgba(255,255,255,0.08); }
  .sc-docs .sc-count   { color: #ffffff; }
  .sc-docs .sc-icon-wrap  { background: rgba(255,255,255,0.08); }

  .sc-music  { background: #141414; border: 1px solid rgba(255,255,255,0.12); }
  .sc-music::before  { background: radial-gradient(circle at 70% 30%, rgba(255,255,255,0.05), transparent 60%); }
  .sc-music:hover    { box-shadow: 0 8px 32px rgba(255,255,255,0.08); }
  .sc-music .sc-count  { color: #ffffff; }
  .sc-music .sc-icon-wrap { background: rgba(255,255,255,0.08); }

  .sc-others { background: #141414; border: 1px solid rgba(255,255,255,0.12); }
  .sc-others::before { background: radial-gradient(circle at 70% 30%, rgba(255,255,255,0.05), transparent 60%); }
  .sc-others:hover   { box-shadow: 0 8px 32px rgba(255,255,255,0.08); }
  .sc-others .sc-count { color: #aaaaaa; }
  .sc-others .sc-icon-wrap { background: rgba(255,255,255,0.05); }

  .sc-icon-wrap { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; color:#ffffff; }
  .sc-label { font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; color:#555555; }
  .sc-count { font-size:2rem; font-weight:800; line-height:1; font-variant-numeric:tabular-nums; }
</style>

<script>
  declare const window: Window & {
    go?: { main?: { App?: {
      GetStats: () => Promise<{ images: number; videos: number; docs: number; music: number; others: number }>;
    } } };
    refreshStats?: () => void;
  };

  const categories = [
    { key: "images", label: "Images", cls: "sc-images",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>` },
    { key: "videos", label: "Videos", cls: "sc-videos",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>` },
    { key: "docs",   label: "Docs",   cls: "sc-docs",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>` },
    { key: "music",  label: "Music",  cls: "sc-music",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg>` },
    { key: "others", label: "Others", cls: "sc-others",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM4 7V5a2 2 0 012-2h12a2 2 0 012 2v2"/></svg>` },
  ];

  function animateCount(el: HTMLElement, target: number) {
    const duration = 650, start = performance.now();
    function tick(now: number) {
      const t = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - t, 3);
      el.textContent = String(Math.round(target * ease));
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function renderCards(data: Record<string, number>) {
    const grid = document.getElementById("stats-grid")!;
    grid.innerHTML = categories.map(cat => `
      <div class="stat-card ${cat.cls}">
        <div class="sc-icon-wrap">${cat.svg}</div>
        <span class="sc-label">${cat.label}</span>
        <span class="sc-count" data-key="${cat.key}">0</span>
      </div>
    `).join("");

    categories.forEach(cat => {
      const el = grid.querySelector<HTMLElement>(`[data-key="${cat.key}"]`);
      if (el) animateCount(el, data[cat.key] ?? 0);
    });
  }

  async function loadStats() {
    const App = window.go?.main?.App;
    if (!App) {
      // dev fallback
      renderCards({ images: 0, videos: 0, docs: 0, music: 0, others: 0 });
      return;
    }
    try {
      const data = await App.GetStats();
      renderCards(data as unknown as Record<string, number>);
    } catch (e) {
      console.error("GetStats error:", e);
      renderCards({ images: 0, videos: 0, docs: 0, music: 0, others: 0 });
    }
  }

  // Expose global refresh hook for FolderSelector to call after organizing
  window.refreshStats = loadStats;

  loadStats();
</script>
