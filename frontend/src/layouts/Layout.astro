---
import '../styles/global.css';
export interface Props { title?: string; }
const { title = 'Smart File Organizer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>/* legacy reset kept for safety */
    *, *::before, *::after { box-sizing: border-box; }
    </style>
  </head>

  <body class="min-h-screen font-sans antialiased" style="background:#000000; color:#e0e0e0;">

    <!-- Subtle dot grid overlay -->
    <div class="fixed inset-0 pointer-events-none" aria-hidden="true"
         style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px;"></div>

    <!-- ── Navbar ───────────────────────────────────────────────── -->
    <header class="sticky top-0 z-50 w-full"
            style="background: rgba(0,0,0,0.85); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.10);">
      <div class="mx-auto max-w-[1200px] px-6 h-16 flex items-center gap-4">

        <!-- Logo -->
        <div class="flex items-center justify-center w-9 h-9 rounded-xl flex-shrink-0"
             style="background: #ffffff; box-shadow: 0 4px 16px rgba(255,255,255,0.15);">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#000000" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h3.586a1 1 0 01.707.293L10.707 6.7A1 1 0 0011.414 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
          </svg>
        </div>

        <!-- Title -->
        <span class="text-lg font-bold tracking-tight" style="color:#ffffff;">Smart File Organizer</span>

        <!-- Divider -->
        <div class="hidden sm:block h-5 w-px mx-1" style="background:rgba(255,255,255,0.15);"></div>
        <span class="hidden sm:block text-xs font-medium" style="color:#555555;">Dashboard</span>

        <!-- Spacer -->
        <div class="flex-1"></div>

        <!-- Status indicator -->
        <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full"
             style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12);">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#ffffff;"></span>
          <span class="text-xs font-medium" style="color:#aaaaaa;">Desktop App</span>
        </div>

        <!-- Version badge -->
        <span class="text-xs font-semibold px-2.5 py-1 rounded-full"
              style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18); color: #ffffff;">v1.0</span>
      </div>

      <!-- Gradient line -->
      <div class="h-px w-full" style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.25) 30%, rgba(255,255,255,0.25) 70%, transparent 100%);"></div>
    </header>

    <!-- ── Page content ──────────────────────────────────────────── -->
    <main class="relative mx-auto max-w-[1200px] px-4 sm:px-6 py-10 flex flex-col gap-8">
      <slot />
    </main>

    <!-- ── Toast container ───────────────────────────────────────── -->
    <div id="toast-root" class="fixed bottom-6 right-6 z-[200] flex flex-col gap-3 items-end pointer-events-none"></div>

    <script is:inline>
      /* Global toast helper — called by child components */
      window.showToast = function(msg, type) {
        const colors = {
          success: { bg: 'rgba(10,10,10,0.97)', border: 'rgba(255,255,255,0.35)', icon: '✓', text: '#ffffff' },
          error:   { bg: 'rgba(10,10,10,0.97)', border: 'rgba(255,255,255,0.2)',  icon: '✕', text: '#ff6b6b' },
          info:    { bg: 'rgba(10,10,10,0.97)', border: 'rgba(255,255,255,0.2)',  icon: 'i', text: '#aaaaaa' },
        };
        const c = colors[type] || colors.info;
        const toast = document.createElement('div');
        toast.style.cssText = `background:${c.bg};border:1px solid ${c.border};color:${c.text};backdrop-filter:blur(16px);padding:0.75rem 1.1rem;border-radius:12px;font-size:0.875rem;font-weight:500;display:flex;align-items:center;gap:0.6rem;max-width:380px;box-shadow:0 8px 32px rgba(0,0,0,0.5);pointer-events:all;`;
        toast.innerHTML = `<span>${c.icon}</span><span>${msg}</span>`;
        toast.classList.add('animate-toast-in');
        const root = document.getElementById('toast-root');
        root.appendChild(toast);
        setTimeout(() => { toast.style.animation = 'toastOut 0.25s ease-in forwards'; setTimeout(() => toast.remove(), 260); }, 3500);
      };
    </script>
  </body>
</html>
